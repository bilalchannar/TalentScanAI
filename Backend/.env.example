# =============================================
# TalentScanAI Backend - Environment Variables
# =============================================
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file to Git.

# --- JWT Authentication ---
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=replace-with-a-long-random-secret-key-here
JWT_EXP_MINUTES=120
RESET_TOKEN_EXP_MINUTES=15

# --- MongoDB ---
MONGO_DATABASE_NAME=TalentScanAI
# For local dev (no Docker):
MONGO_CONNECTION_URL=mongodb://127.0.0.1:27017
# For Docker Compose (use this instead):
# MONGO_CONNECTION_URL=mongodb://mongo:27017/TalentScanAI

# --- CORS ---
# Comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:5000,http://127.0.0.1:5000,http://localhost:5173,http://127.0.0.1:5173

# --- Email (for password reset via Gmail) ---
# Use a Gmail App Password (NOT your real Gmail password)
# How to get: Google Account → Security → 2-Step Verification → App passwords
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASS=your-gmail-app-password-here

# --- Client URL (used in reset email link) ---
CLIENT_URL=http://localhost:5000

# --- Feature Flags ---
# Set to "true" to allow anyone to sign up as a recruiter
ALLOW_PUBLIC_RECRUITER_SIGNUP=false
# Set to "true" ONLY for local dev - exposes reset token in API response
EXPOSE_RESET_TOKEN=false
# Set to "true" to show detailed errors in API responses (dev only)
FLASK_DEBUG=false
